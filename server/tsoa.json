{
  "entryFile": "src/index.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": ["src/controllers/**/*Controller.ts"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] }
  },
  "spec": {
    "outputDirectory": "src/generated",
    "specVersion": 3,
    "info": {
      "title": "Message API",
      "version": "1.0.0",
      "description": "Automatically generated API documentation via tsoa."
    }
  },
  "routes": {
    "routesDir": "src/generated",
    "middleware": "express",
    "iocModule": "",
    "esm": true
  }
}
